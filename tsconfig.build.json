/* Visit Visit https://www.typescriptlang.org/tsconfig to read more about this file */
{
    "extends": [
        "./tsconfig.json",
        "./tsconfig-build-options.json"
    ],
    "compilerOptions": {
        "allowSyntheticDefaultImports": true,
        "outDir": "./build"
    },
    "exclude": [
        "packages/agoric-cli",
        "packages/benchmark",
        "packages/cosmic-swingset",
        "packages/deployment",
        "packages/eslint-plugin", // FIXME module resolution issues
        "packages/import-manager",
        "packages/inter-protocol",
        "packages/create-dapp",
        "packages/solo",
        "packages/stat-logger",
        "packages/swingset-runner",
        "packages/telemetry",
        "packages/xsnap/moddable",
        "packages/xsnap/xsnap-native",
        "packages/xsnap-lockdown",
        "a3p-integration",
        "multichain-testing",
        "services", // FIXME generated code lacks the filename extension
        "packages/orchestration/src/vendor",
        "packages/swingset-liveslots/tools/vo-test-harness.js",
        "packages/vats/tools/boot-test-utils.js",
        "**/build",
        "**/dist",
        "**/docs",
        "**/*.umd.js",
        "**/scripts",
        "**/test"
    ],
    "include": [
        "./**/*.ts",
        "packages/**/*.js"
    ]
}
