{
  "name": "@agoric/governance",
  "version": "0.10.3",
  "description": "Core governance support",
  "type": "module",
  "main": "src/index.js",
  "engines": {
    "node": "^22.11"
  },
  "scripts": {
    "prepack": "yarn run -T prepack-package",
    "postpack": "yarn run -T postpack-package",
    "test": "ava",
    "test:c8": "c8 --all ${C8_OPTIONS:-} ava",
    "test:xs": "exit 0",
    "lint-fix": "yarn lint:eslint --fix",
    "lint": "yarn run -T run-s --continue-on-error 'lint:*'",
    "lint:eslint": "node ../../scripts/eslint-repo.mjs .",
    "lint:types": "yarn run -T tsgo --tsBuildInfoFile tsconfig.tsgo.tsbuildinfo"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Agoric/agoric-sdk.git"
  },
  "author": "Agoric",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/Agoric/agoric-sdk/issues"
  },
  "homepage": "https://github.com/Agoric/agoric-sdk#readme",
  "dependencies": {
    "@agoric/ertp": "workspace:*",
    "@agoric/internal": "workspace:*",
    "@agoric/notifier": "workspace:*",
    "@agoric/store": "workspace:*",
    "@agoric/time": "workspace:*",
    "@agoric/vat-data": "workspace:*",
    "@agoric/zoe": "workspace:*",
    "@endo/bundle-source": "^4.3.2",
    "@endo/captp": "^4.5.1",
    "@endo/errors": "^1.3.1",
    "@endo/eventual-send": "^1.5.0",
    "@endo/far": "^1.1.14",
    "@endo/marshal": "^1.10.0",
    "@endo/nat": "^5.2.0",
    "@endo/promise-kit": "^1.2.1",
    "import-meta-resolve": "^4.1.0"
  },
  "devDependencies": {
    "@agoric/swingset-vat": "workspace:*",
    "@endo/bundle-source": "^4.3.2",
    "@endo/init": "^1.1.13",
    "ava": "^8.0.1",
    "c8": "^10.1.3"
  },
  "files": [
    "README.md",
    "src/",
    "source-spec-registry.*",
    "tools/",
    "NEWS.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "typeCoverage": {
    "atLeast": 89.65
  }
}
