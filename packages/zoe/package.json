{
  "name": "@agoric/zoe",
  "version": "0.26.2",
  "description": "Zoe: the Smart Contract Framework for Offer Enforcement",
  "type": "module",
  "main": "./src/zoeService/zoe.js",
  "engines": {
    "node": "^22.11"
  },
  "scripts": {
    "prepack": "yarn run -T prepack-package",
    "postpack": "yarn run -T postpack-package",
    "test": "ava --verbose",
    "test:c8": "c8 --all ${C8_OPTIONS:-} ava",
    "test:unit": "ava 'test/unitTests' -T 2m --verbose",
    "test:swingset": "ava 'test/swingsetTests' -T 10m --verbose",
    "test:xs": "yarn test:xs-worker",
    "test:xs-unit": "exit 0",
    "test:xs-worker": "SWINGSET_WORKER_TYPE=xs-worker ava -c 2 'test/swingsetTests'",
    "lint-fix": "yarn lint:eslint --fix",
    "lint": "yarn run -T run-s --continue-on-error 'lint:*'",
    "lint:eslint": "node ../../scripts/eslint-repo.mjs .",
    "lint:types": "yarn run -T tsgo --tsBuildInfoFile tsconfig.tsgo.tsbuildinfo"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Agoric/agoric-sdk.git"
  },
  "keywords": [
    "smart",
    "contract",
    "cryptocurrency",
    "exchange",
    "tokens"
  ],
  "author": "Agoric",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/Agoric/agoric-sdk/issues"
  },
  "homepage": "https://github.com/Agoric/agoric-sdk#readme",
  "dependencies": {
    "@agoric/base-zone": "workspace:*",
    "@agoric/ertp": "workspace:*",
    "@agoric/internal": "workspace:*",
    "@agoric/notifier": "workspace:*",
    "@agoric/store": "workspace:*",
    "@agoric/swingset-liveslots": "workspace:*",
    "@agoric/swingset-vat": "workspace:*",
    "@agoric/time": "workspace:*",
    "@agoric/vat-data": "workspace:*",
    "@agoric/vow": "workspace:*",
    "@agoric/zone": "workspace:*",
    "@endo/bundle-source": "^4.3.2",
    "@endo/captp": "^4.5.1",
    "@endo/common": "^1.4.0",
    "@endo/errors": "^1.3.1",
    "@endo/eventual-send": "^1.5.0",
    "@endo/exo": "^1.7.0",
    "@endo/far": "^1.1.14",
    "@endo/import-bundle": "^1.7.0",
    "@endo/marshal": "^1.10.0",
    "@endo/nat": "^5.2.0",
    "@endo/pass-style": "^1.8.1",
    "@endo/patterns": "^1.9.1",
    "@endo/promise-kit": "^1.2.1",
    "yargs-parser": "^21.1.1"
  },
  "devDependencies": {
    "@agoric/kmarshal": "workspace:*",
    "@endo/init": "^1.1.13",
    "ava": "^8.0.1",
    "c8": "^10.1.3",
    "import-meta-resolve": "^4.1.0",
    "tsd": "^0.33.0"
  },
  "files": [
    "bundles/",
    "src/",
    "source-spec-registry.*",
    "tools/",
    "contractFacet.js",
    "NEWS.md"
  ],
  "ava": {
    "files": [
      "test/**/*.test.*"
    ],
    "require": [
      "@endo/init/debug.js"
    ],
    "timeout": "20m"
  },
  "publishConfig": {
    "access": "public"
  },
  "typeCoverage": {
    "atLeast": 84.74
  }
}
