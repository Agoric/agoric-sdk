{
  "name": "@agoric/internal",
  "version": "0.3.2",
  "description": "Externally unsupported utilities internal to agoric-sdk",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Agoric/agoric-sdk.git"
  },
  "type": "module",
  "main": "src/index.js",
  "engines": {
    "node": "^22.11"
  },
  "scripts": {
    "build": "exit 0",
    "prepack": "yarn run -T prepack-package",
    "postpack": "yarn run -T postpack-package",
    "test": "ava",
    "test:nyc": "exit 0",
    "test:xs": "exit 0",
    "lint-fix": "yarn lint:eslint --fix",
    "lint": "yarn run -T run-s --continue-on-error 'lint:*'",
    "lint:eslint": "node ../../scripts/eslint-repo.mjs .",
    "lint:types": "yarn run -T tsgo --tsBuildInfoFile tsconfig.tsgo.tsbuildinfo"
  },
  "dependencies": {
    "@agoric/base-zone": "workspace:*",
    "@endo/cache-map": "^1.1.0",
    "@endo/common": "^1.4.0",
    "@endo/compartment-mapper": "^2.3.0",
    "@endo/errors": "^1.3.1",
    "@endo/eventual-send": "^1.5.0",
    "@endo/far": "^1.1.14",
    "@endo/init": "^1.1.13",
    "@endo/marshal": "^1.10.0",
    "@endo/nat": "^5.2.0",
    "@endo/pass-style": "^1.8.1",
    "@endo/patterns": "^1.9.1",
    "@endo/promise-kit": "^1.2.1",
    "@endo/stream": "^1.3.1",
    "import-meta-resolve": "^4.1.0",
    "jessie.js": "^0.3.4"
  },
  "devDependencies": {
    "@agoric/cosmic-proto": "workspace:*",
    "@endo/exo": "^1.7.0",
    "@endo/init": "^1.1.13",
    "@endo/ses-ava": "^1.4.2",
    "@fast-check/ava": "^3.0.1",
    "ava": "^7.0.0",
    "tsd": "^0.33.0"
  },
  "ava": {
    "require": [
      "@endo/init/debug.js"
    ],
    "files": [
      "test/**/*.test.*"
    ]
  },
  "author": "Agoric",
  "license": "Apache-2.0",
  "files": [
    "src",
    "vendor"
  ],
  "publishConfig": {
    "access": "public"
  },
  "typeCoverage": {
    "atLeast": 95.63
  }
}
