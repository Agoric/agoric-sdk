{
  "name": "@agoric/vow",
  "version": "0.1.0",
  "description": "Remote (shortening and disconnection-tolerant) Promise-likes",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Agoric/agoric-sdk.git"
  },
  "type": "module",
  "main": "src/index.js",
  "engines": {
    "node": "^22.11"
  },
  "scripts": {
    "build": "exit 0",
    "prepack": "yarn run -T prepack-package",
    "postpack": "yarn run -T postpack-package",
    "test": "ava",
    "test:xs": "exit 0",
    "test:xs:ci": "npm run test:xs",
    "lint-fix": "yarn lint:eslint --fix",
    "lint": "yarn run -T run-s --continue-on-error 'lint:*'",
    "lint:eslint": "node ../../scripts/eslint-repo.mjs .",
    "lint:types": "yarn run -T tsgo --tsBuildInfoFile tsconfig.tsgo.tsbuildinfo"
  },
  "dependencies": {
    "@agoric/base-zone": "workspace:*",
    "@agoric/internal": "workspace:*",
    "@endo/env-options": "^1.1.11",
    "@endo/errors": "^1.3.1",
    "@endo/eventual-send": "^1.5.0",
    "@endo/pass-style": "^1.8.1",
    "@endo/patterns": "^1.9.1",
    "@endo/promise-kit": "^1.2.1"
  },
  "devDependencies": {
    "@agoric/internal": "workspace:*",
    "@agoric/swingset-vat": "workspace:*",
    "@agoric/zone": "workspace:*",
    "@endo/far": "^1.1.14",
    "@endo/init": "^1.1.13",
    "ava": "^8.0.1",
    "tsd": "^0.33.0"
  },
  "ava": {
    "require": [
      "@endo/init/debug.js"
    ],
    "files": [
      "test/**/*.test.*"
    ]
  },
  "author": "Agoric",
  "license": "Apache-2.0",
  "files": [
    "*.js",
    "src"
  ],
  "publishConfig": {
    "access": "public"
  },
  "typeCoverage": {
    "atLeast": 90.7
  }
}
