{
  "steps": [
    [
      "@agoric/builders/scripts/vats/init-core.js"
    ],
    [
      "@agoric/builders/scripts/vats/init-network.js",
      "@agoric/builders/scripts/vats/init-localchain.js",
      "@agoric/builders/scripts/vats/init-transfer.js"
    ],
    [
      {
        "module": "@agoric/builders/scripts/vats/start-econ-committee.js",
        "entrypoint": "defaultProposalBuilder",
        "args": [
          {
            "econCommitteeOptions": {
              "committeeSize": 1
            }
          }
        ]
      },
      {
        "module": "@agoric/builders/scripts/vats/invite-committee.js",
        "entrypoint": "defaultProposalBuilder",
        "args": [
          {
            "voterAddresses": {
              "someone": "@PRIMARY_ADDRESS@"
            }
          }
        ]
      }
    ]
  ]
}
