{
  "name": "@agoric/client-utils",
  "version": "0.1.0",
  "description": "Utilities for building Agoric clients",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Agoric/agoric-sdk.git"
  },
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "dist/main.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "yarn run -T tsc --build tsconfig.build.json",
    "codegen": "scripts/codegen.cjs",
    "prepack": "yarn run -T prepack-package",
    "postpack": "yarn run -T postpack-package",
    "test": "ava",
    "test:c8": "c8 --all ${C8_OPTIONS:-} ava",
    "test:xs": "exit 0",
    "lint-fix": "yarn lint:eslint --fix",
    "lint": "yarn run -T run-s --continue-on-error 'lint:*'",
    "lint:eslint": "node ../../scripts/eslint-repo.mjs .",
    "lint:types": "yarn run -T tsgo --tsBuildInfoFile tsconfig.tsgo.tsbuildinfo"
  },
  "devDependencies": {
    "@agoric/smart-wallet": "workspace:*",
    "@agoric/vats": "workspace:*",
    "@agoric/zoe": "workspace:*",
    "@hyperweb/telescope": "^2.2.1",
    "ava": "^8.0.1",
    "c8": "^10.1.3",
    "rimraf": "^6.0.1",
    "ts-blank-space": "^0.6.2"
  },
  "dependencies": {
    "@agoric/casting": "workspace:*",
    "@agoric/cosmic-proto": "workspace:*",
    "@agoric/ertp": "workspace:*",
    "@agoric/internal": "workspace:*",
    "@cosmjs/crypto": "^0.36.0",
    "@cosmjs/proto-signing": "^0.36.0",
    "@cosmjs/stargate": "^0.36.0",
    "@cosmjs/tendermint-rpc": "^0.36.0",
    "@endo/base64": "^1.1.1",
    "@endo/common": "^1.4.0",
    "@endo/errors": "^1.3.1",
    "@endo/marshal": "^1.10.0",
    "@endo/pass-style": "^1.8.1",
    "@endo/patterns": "^1.9.1",
    "@endo/promise-kit": "^1.2.1",
    "@interchainjs/cosmos": "^1.19.3",
    "@interchainjs/types": "^1.19.1"
  },
  "ava": {
    "extensions": [
      "js",
      "ts"
    ],
    "files": [
      "test/**/*.test.*"
    ],
    "nodeArguments": [
      "--import=ts-blank-space/register",
      "--no-warnings"
    ],
    "require": [
      "@endo/init/legacy.js"
    ],
    "timeout": "20m"
  },
  "typeCoverage": {
    "atLeast": 93.99
  },
  "engines": {
    "node": "^22.11"
  }
}
