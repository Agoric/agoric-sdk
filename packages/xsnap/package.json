{
  "name": "@agoric/xsnap",
  "version": "0.14.2",
  "description": "Snapshotting VM worker based on Moddable's XS Javascript engine",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Agoric/agoric-sdk.git"
  },
  "author": "Agoric",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./src/index.js",
  "bin": {
    "ava-xs": "./src/ava-xs.js",
    "xsrepl": "./src/xsrepl"
  },
  "scripts": {
    "repl": "node src/xsrepl.js",
    "install:prebuilt": "node src/install-prebuilt.js",
    "build": "yarn install:prebuilt",
    "check-version": "/bin/sh -c 'if test \"${npm_package_version}\" != \"$(./scripts/get_xsnap_version.sh)\"; then echo \"xsnap version mismatch; expected '${npm_package_version}'\"; exit 1; fi'",
    "postinstall": "npm run install:prebuilt",
    "clean": "rm -rf xsnap-native/xsnap/build",
    "lint": "yarn run -T run-s --continue-on-error 'lint:*'",
    "lint:eslint": "node ../../scripts/eslint-repo.mjs 'src/**/*.js' 'test/**/*.js' api.js",
    "lint:types": "yarn run -T tsgo --tsBuildInfoFile tsconfig.tsgo.tsbuildinfo",
    "lint-fix": "yarn lint:eslint --fix",
    "test": "ava",
    "test:c8": "c8 --all ${C8_OPTIONS:-} ava",
    "test:xs": "exit 0"
  },
  "dependencies": {
    "@agoric/xsnap-lockdown": "workspace:*",
    "@endo/bundle-source": "^4.3.2",
    "@endo/errors": "^1.3.1",
    "@endo/eventual-send": "^1.5.0",
    "@endo/init": "^1.1.13",
    "@endo/netstring": "^1.1.1",
    "@endo/promise-kit": "^1.2.1",
    "@endo/stream": "^1.3.1",
    "@endo/stream-node": "^1.2.1",
    "tmp": "^0.2.1"
  },
  "devDependencies": {
    "@agoric/internal": "workspace:*",
    "@endo/base64": "^1.1.1",
    "@endo/nat": "^5.2.0",
    "ava": "^7.0.0",
    "c8": "^10.1.3",
    "execa": "^9.5.2",
    "ses": "^2.2.0"
  },
  "files": [
    "LICENSE*",
    "api.js",
    "scripts/**",
    "src/**"
  ],
  "publishConfig": {
    "access": "public"
  },
  "ava": {
    "files": [
      "test/**/*.test.*"
    ],
    "require": [
      "@endo/init/debug.js"
    ],
    "timeout": "2m"
  },
  "typeCoverage": {
    "atLeast": 93.57
  },
  "engines": {
    "node": "^22.11"
  }
}
