{
  "name": "@aglocal/boot",
  "version": "0.1.0",
  "private": true,
  "description": "Config and utilities to bootstrap an Agoric chain",
  "type": "module",
  "repository": "https://github.com/Agoric/agoric-sdk",
  "scripts": {
    "build": "exit 0",
    "clean": "rm -rf bundles test/cache",
    "test": "ava",
    "test:xs": "SWINGSET_WORKER_TYPE=xs-worker ava test",
    "make:runutils-snapshot": "node --import ts-blank-space/register ./test/tools/create-runutils-snapshot.ts",
    "make:runutils-snapshots": "node --import ts-blank-space/register ./test/tools/create-runutils-snapshot.ts --all",
    "print:runutils-snapshot-cache-key": "node --import ts-blank-space/register ./test/tools/create-runutils-snapshot.ts --cache-key",
    "lint-fix": "yarn lint:eslint --fix",
    "lint": "yarn run -T run-s --continue-on-error 'lint:*'",
    "lint:types": "yarn run -T tsgo --tsBuildInfoFile tsconfig.tsgo.tsbuildinfo",
    "lint:eslint": "node ../../scripts/eslint-repo.mjs .",
    "lint:exports": "node scripts/check-unused-exports.js"
  },
  "keywords": [],
  "author": "Agoric",
  "license": "Apache-2.0",
  "dependencies": {
    "@agoric/builders": "workspace:*",
    "@agoric/client-utils": "workspace:*",
    "@agoric/cosmic-proto": "workspace:*",
    "@agoric/cosmic-swingset": "workspace:*",
    "@agoric/ertp": "workspace:*",
    "@agoric/governance": "workspace:*",
    "@agoric/internal": "workspace:*",
    "@agoric/kmarshal": "workspace:*",
    "@agoric/network": "workspace:*",
    "@agoric/notifier": "workspace:*",
    "@agoric/orchestration": "workspace:*",
    "@agoric/smart-wallet": "workspace:*",
    "@agoric/swing-store": "workspace:*",
    "@agoric/swingset-vat": "workspace:*",
    "@agoric/telemetry": "workspace:*",
    "@agoric/time": "workspace:*",
    "@agoric/vat-data": "workspace:*",
    "@agoric/vats": "workspace:*",
    "@agoric/vm-config": "workspace:*",
    "@agoric/vow": "workspace:*",
    "@agoric/zoe": "workspace:*",
    "@agoric/zone": "workspace:*",
    "@endo/base64": "^1.1.1",
    "@endo/bundle-source": "^4.3.2",
    "@endo/captp": "^4.5.1",
    "@endo/errors": "^1.3.1",
    "@endo/eventual-send": "^1.5.0",
    "@endo/far": "^1.1.14",
    "@endo/init": "^1.1.13",
    "@endo/marshal": "^1.10.0",
    "@endo/patterns": "^1.9.1",
    "@endo/promise-kit": "^1.2.1",
    "@endo/stream": "^1.3.1",
    "import-meta-resolve": "^4.1.0",
    "node-fetch-cache": "^5.0.2",
    "tmp": "^0.2.1",
    "viem": "^2.31.0"
  },
  "devDependencies": {
    "@agoric/deploy-script-support": "workspace:*",
    "@agoric/governance": "workspace:*",
    "@agoric/store": "workspace:*",
    "@agoric/swingset-liveslots": "workspace:*",
    "@endo/base64": "^1.1.1",
    "ava": "^7.0.0",
    "c8": "^10.1.3",
    "ts-blank-space": "^0.6.2"
  },
  "files": [
    "CHANGELOG.md",
    "src/",
    "scripts/",
    "tools/",
    "*.json"
  ],
  "engines": {
    "node": "^22.11 || ^24.14"
  },
  "typeCoverage": {
    "atLeast": 92.21
  }
}
