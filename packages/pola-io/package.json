{
  "name": "@agoric/pola-io",
  "version": "0.1.0",
  "description": "Least Authority I/O utilities",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Agoric/agoric-sdk.git"
  },
  "type": "module",
  "main": "./src/index.js",
  "scripts": {
    "build": "exit 0",
    "test": "ava",
    "test:xs": "exit 0",
    "lint": "yarn run -T run-s --continue-on-error 'lint:*'",
    "lint:eslint": "node ../../scripts/eslint-repo.mjs .",
    "lint:types": "yarn run -T tsgo --tsBuildInfoFile tsconfig.tsgo.tsbuildinfo",
    "lint-fix": "yarn lint:eslint --fix"
  },
  "dependencies": {
    "@agoric/internal": "workspace:*"
  },
  "devDependencies": {
    "ava": "^8.0.1"
  },
  "files": [
    "src/"
  ],
  "publishConfig": {
    "access": "public"
  },
  "eslintConfig": {
    "extends": [
      "@agoric"
    ]
  },
  "ava": {
    "files": [
      "test/**/*.test.*"
    ],
    "timeout": "2m"
  },
  "typeCoverage": {
    "atLeast": 92.3
  },
  "engines": {
    "node": "^22.11"
  }
}
