{
  "name": "@agoric/telemetry",
  "version": "0.6.2",
  "description": "Agoric's telemetry implementation",
  "type": "module",
  "repository": "https://github.com/Agoric/agoric-sdk",
  "main": "./src/index.js",
  "scripts": {
    "build": "exit 0",
    "test": "ava",
    "test:c8": "c8 --all ${C8_OPTIONS:-} ava",
    "test:xs": "exit 0",
    "lint-fix": "yarn lint:eslint --fix",
    "lint": "yarn run -T run-s --continue-on-error 'lint:*'",
    "lint:types": "yarn run -T tsgo --tsBuildInfoFile tsconfig.tsgo.tsbuildinfo",
    "lint:eslint": "node ../../scripts/eslint-repo.mjs ."
  },
  "bin": {
    "frcat": "./src/frcat-entrypoint.js"
  },
  "keywords": [],
  "author": "Agoric",
  "license": "Apache-2.0",
  "dependencies": {
    "@agoric/internal": "workspace:*",
    "@agoric/store": "workspace:*",
    "@endo/errors": "^1.3.1",
    "@endo/init": "^1.1.13",
    "@endo/marshal": "^1.10.0",
    "@endo/promise-kit": "^1.2.1",
    "@endo/stream": "^1.3.1",
    "@opentelemetry/api": "~1.9.0",
    "@opentelemetry/api-logs": "0.57.1",
    "@opentelemetry/exporter-logs-otlp-http": "0.57.1",
    "@opentelemetry/exporter-prometheus": "~0.57.1",
    "@opentelemetry/exporter-trace-otlp-http": "0.57.1",
    "@opentelemetry/resources": "~1.30.1",
    "@opentelemetry/sdk-logs": "0.57.1",
    "@opentelemetry/sdk-metrics": "~1.30.1",
    "@opentelemetry/sdk-trace-base": "~1.30.1",
    "@opentelemetry/semantic-conventions": "~1.28.0",
    "better-sqlite3": "^12.10.0",
    "tmp": "^0.2.1"
  },
  "devDependencies": {
    "@endo/lockdown": "^1.0.19",
    "@endo/ses-ava": "^1.4.2",
    "ava": "^7.0.0",
    "c8": "^10.1.3",
    "tmp": "^0.2.1"
  },
  "files": [
    "src"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": "^22.11 || ^24.14"
  },
  "ava": {
    "files": [
      "test/**/*.test.*"
    ],
    "require": [
      "@endo/init/debug.js"
    ],
    "timeout": "20m"
  },
  "typeCoverage": {
    "atLeast": 89.28
  }
}
