{
  "name": "@agoric/swingset-vat",
  "version": "0.32.2",
  "description": "Vat/Container Launcher",
  "type": "module",
  "main": "src/index.js",
  "engines": {
    "node": "^22.11 || ^24.14"
  },
  "bin": {
    "vat": "bin/vat"
  },
  "scripts": {
    "build": "exit 0",
    "test": "ava",
    "test:c8": "c8 --all ${C8_OPTIONS:-} ava",
    "test:xs": "SWINGSET_WORKER_TYPE=xs-worker ava",
    "test:xs-worker": "ava test/workers -m 'xsnap vat manager'",
    "lint-fix": "yarn lint:eslint --fix",
    "lint": "yarn run -T run-s --continue-on-error 'lint:*'",
    "lint:types": "yarn run -T tsgo --tsBuildInfoFile tsconfig.tsgo.tsbuildinfo",
    "lint:eslint": "node ../../scripts/eslint-repo.mjs ."
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/microtime": "^2.1.0",
    "@types/tmp": "^0.2.0",
    "ava": "^8.0.1"
  },
  "dependencies": {
    "@agoric/internal": "workspace:*",
    "@agoric/kmarshal": "workspace:*",
    "@agoric/store": "workspace:*",
    "@agoric/swing-store": "workspace:*",
    "@agoric/swingset-liveslots": "workspace:*",
    "@agoric/swingset-xsnap-supervisor": "workspace:*",
    "@agoric/time": "workspace:*",
    "@agoric/vat-data": "workspace:*",
    "@agoric/xsnap-lockdown": "workspace:*",
    "@endo/base64": "^1.1.1",
    "@endo/bundle-source": "^4.3.2",
    "@endo/captp": "^4.5.1",
    "@endo/check-bundle": "^1.1.1",
    "@endo/compartment-mapper": "^2.3.0",
    "@endo/errors": "^1.3.1",
    "@endo/eventual-send": "^1.5.0",
    "@endo/far": "^1.1.14",
    "@endo/import-bundle": "^1.7.0",
    "@endo/init": "^1.1.13",
    "@endo/marshal": "^1.10.0",
    "@endo/nat": "^5.2.0",
    "@endo/pass-style": "^1.8.1",
    "@endo/patterns": "^1.9.1",
    "@endo/promise-kit": "^1.2.1",
    "@endo/ses-ava": "^1.4.2",
    "@endo/stream": "^1.3.1",
    "@endo/zip": "^1.1.0",
    "ansi-styles": "^6.2.1",
    "better-sqlite3": "^12.10.0",
    "import-meta-resolve": "^4.1.0",
    "microtime": "^3.1.0",
    "semver": "^6.3.0",
    "tmp": "^0.2.1"
  },
  "peerDependencies": {
    "@agoric/xsnap": "workspace:*",
    "ava": "*"
  },
  "files": [
    "bin/vat",
    "src/**/*.js",
    "src/**/*.d.ts",
    "tools"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Agoric/agoric-sdk.git"
  },
  "author": "Agoric",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/Agoric/agoric-sdk/issues"
  },
  "homepage": "https://github.com/Agoric/agoric-sdk#readme",
  "directories": {
    "example": "examples"
  },
  "publishConfig": {
    "access": "public"
  },
  "typeCoverage": {
    "atLeast": 77.18
  }
}
