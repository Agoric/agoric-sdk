{
  "name": "@agoric/swingset-liveslots",
  "version": "0.10.2",
  "description": "SwingSet ocap support layer",
  "type": "module",
  "main": "src/index.js",
  "engines": {
    "node": "^20.9 || ^22.11"
  },
  "scripts": {
    "build": "exit 0",
    "test": "ava",
    "test:xs": "exit 0",
    "lint-fix": "yarn lint:eslint --fix",
    "lint": "yarn run -T run-s --continue-on-error 'lint:*'",
    "lint:types": "yarn run -T tsc",
    "lint:eslint": "yarn run -T eslint .",
    "prepack": "yarn run -T prepack-package",
    "postpack": "yarn run -T postpack-package"
  },
  "dependencies": {
    "@agoric/internal": "workspace:*",
    "@agoric/store": "workspace:*",
    "@endo/env-options": "^1.1.11",
    "@endo/errors": "^1.3.0",
    "@endo/eventual-send": "^1.4.0",
    "@endo/exo": "^1.6.0",
    "@endo/far": "^1.1.14",
    "@endo/init": "^1.1.13",
    "@endo/marshal": "^1.9.0",
    "@endo/nat": "^5.2.0",
    "@endo/pass-style": "^1.7.0",
    "@endo/patterns": "^1.8.0",
    "@endo/promise-kit": "^1.2.0"
  },
  "devDependencies": {
    "@agoric/kmarshal": "workspace:*",
    "ava": "^6.4.1"
  },
  "files": [
    "src",
    "tools"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Agoric/agoric-sdk.git"
  },
  "author": "Agoric",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/Agoric/agoric-sdk/issues"
  },
  "homepage": "https://github.com/Agoric/agoric-sdk#readme",
  "ava": {
    "files": [
      "test/**/*.test.*"
    ],
    "require": [
      "@endo/init/debug.js"
    ],
    "workerThreads": false,
    "timeout": "20m"
  },
  "publishConfig": {
    "access": "public"
  },
  "typeCoverage": {
    "atLeast": 75.22
  }
}
