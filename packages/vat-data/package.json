    "@endo/exo": "^1.7.0",
    "@endo/patterns": "^1.9.1"
  },
  "devDependencies": {
    "@endo/far": "^1.1.14",
    "@endo/init": "^1.1.13",
    "@endo/ses-ava": "^1.4.2",
    "ava": "^8.0.1",
