{
  "name": "@agoric/base-zone",
  "version": "0.1.0",
  "description": "Allocation zone abstraction library and heap implementation",
  "type": "module",
  "repository": "https://github.com/Agoric/agoric-sdk",
  "main": "./src/index.js",
  "scripts": {
    "build": "exit 0",
    "prepack": "yarn run -T prepack-package",
    "postpack": "yarn run -T postpack-package",
    "test": "ava",
    "test:c8": "c8 --all ${C8_OPTIONS:-} ava",
    "test:xs": "exit 0",
    "lint-fix": "yarn lint:eslint --fix",
    "lint": "yarn run -T run-s --continue-on-error 'lint:*'",
    "lint:types": "yarn run -T tsgo --tsBuildInfoFile tsconfig.tsgo.tsbuildinfo",
    "lint:eslint": "node ../../scripts/eslint-repo.mjs ."
  },
  "exports": {
    ".": "./src/index.js",
    "./zone-helpers.js": "./zone-helpers.js",
    "./heap.js": "./heap.js",
    "./tools/*": "./tools/*"
  },
  "keywords": [],
  "author": "Agoric",
  "license": "Apache-2.0",
  "dependencies": {
    "@agoric/store": "workspace:*",
    "@endo/common": "^1.4.0",
    "@endo/errors": "^1.3.1",
    "@endo/exo": "^1.7.0",
    "@endo/far": "^1.1.14",
    "@endo/pass-style": "^1.8.1",
    "@endo/patterns": "^1.9.1"
  },
  "devDependencies": {
    "@endo/init": "^1.1.13",
    "@endo/ses-ava": "^1.4.2",
    "ava": "^7.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": "^22.11 || ^24.14"
  },
  "ava": {
    "files": [
      "test/**/*.test.*"
    ],
    "require": [
      "@endo/init/debug.js"
    ],
    "timeout": "20m"
  },
  "typeCoverage": {
    "atLeast": 93.46
  }
}
