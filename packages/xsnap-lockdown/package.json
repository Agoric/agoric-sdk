{
  "name": "@agoric/xsnap-lockdown",
  "version": "0.14.0",
  "description": "Endo/lockdown initialization bundle for xsnap workers",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Agoric/agoric-sdk.git"
  },
  "author": "Agoric",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./src/index.js",
  "scripts": {
    "build": "node scripts/build-bundle.js",
    "clean": "rm -rf dist",
    "lint": "yarn run -T run-s --continue-on-error 'lint:*'",
    "lint:eslint": "node ../../scripts/eslint-repo.mjs 'src/**/*.js' 'lib/**/*.js' 'scripts/**/*.js' 'test/**/*.js'",
    "lint:types": "yarn run -T tsgo --tsBuildInfoFile tsconfig.tsgo.tsbuildinfo",
    "lint-fix": "yarn lint:eslint --fix",
    "test": "ava",
    "test:c8": "c8 --all ${C8_OPTIONS:-} ava",
    "test:xs": "exit 0"
  },
  "devDependencies": {
    "@endo/bundle-source": "^4.3.2",
    "@endo/init": "^1.1.13",
    "ava": "^7.0.0",
    "c8": "^10.1.3",
    "source-map": "^0.7.4"
  },
  "files": [
    "LICENSE*",
    "lib",
    "dist",
    "src"
  ],
  "publishConfig": {
    "access": "public"
  },
  "ava": {
    "files": [
      "test/**/*.test.*"
    ],
    "require": [
      "@endo/init/debug.js"
    ],
    "timeout": "2m"
  },
  "typeCoverage": {
    "atLeast": 74.81
  },
  "engines": {
    "node": "^22.11 || ^24.14"
  }
}
