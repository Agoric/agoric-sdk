{
  "name": "@agoric/cache",
  "version": "0.3.2",
  "description": "Agoric's simple cache interface",
  "type": "module",
  "main": "src/main.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Agoric/agoric-sdk.git"
  },
  "scripts": {
    "build": "exit 0",
    "test": "ava",
    "test:c8": "c8 --all ${C8_OPTIONS:-} ava",
    "test:xs": "exit 0",
    "lint-fix": "yarn lint:eslint --fix",
    "lint": "yarn run -T run-s --continue-on-error 'lint:*'",
    "lint:types": "yarn run -T tsgo --tsBuildInfoFile tsconfig.tsgo.tsbuildinfo",
    "lint:eslint": "node ../../scripts/eslint-repo.mjs ."
  },
  "keywords": [],
  "author": "Agoric",
  "license": "Apache-2.0",
  "dependencies": {
    "@agoric/internal": "workspace:*",
    "@agoric/notifier": "workspace:*",
    "@agoric/store": "workspace:*",
    "@agoric/vat-data": "workspace:*",
    "@endo/far": "^1.1.14",
    "@endo/marshal": "^1.10.0"
  },
  "devDependencies": {
    "@agoric/zoe": "workspace:*",
    "ava": "^8.0.1",
    "c8": "^10.1.3"
  },
  "files": [
    "src"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": "^22.11"
  },
  "ava": {
    "files": [
      "test/**/*.test.*"
    ],
    "timeout": "20m"
  },
  "typeCoverage": {
    "atLeast": 94.13
  }
}
