{
  "name": "@agoric/vats",
  "version": "0.15.1",
  "description": "Agoric's Vat library",
  "type": "module",
  "main": "./index.js",
  "repository": "https://github.com/Agoric/agoric-sdk",
  "scripts": {
    "test": "ava",
    "test:c8": "c8 --all ${C8_OPTIONS:-} ava",
    "test:xs": "exit 0",
    "lint-fix": "yarn lint:eslint --fix",
    "lint": "yarn run -T run-s --continue-on-error 'lint:*'",
    "lint:types": "yarn run -T tsgo --tsBuildInfoFile tsconfig.tsgo.tsbuildinfo",
    "lint:eslint": "node ../../scripts/eslint-repo.mjs ."
  },
  "keywords": [],
  "author": "Agoric",
  "license": "Apache-2.0",
  "dependencies": {
    "@agoric/cosmic-proto": "workspace:*",
    "@agoric/ertp": "workspace:*",
    "@agoric/governance": "workspace:*",
    "@agoric/internal": "workspace:*",
    "@agoric/network": "workspace:*",
    "@agoric/notifier": "workspace:*",
    "@agoric/store": "workspace:*",
    "@agoric/swingset-vat": "workspace:*",
    "@agoric/time": "workspace:*",
    "@agoric/vat-data": "workspace:*",
    "@agoric/vow": "workspace:*",
    "@agoric/zoe": "workspace:*",
    "@agoric/zone": "workspace:*",
    "@endo/errors": "^1.3.1",
    "@endo/far": "^1.1.14",
    "@endo/import-bundle": "^1.7.0",
    "@endo/marshal": "^1.10.0",
    "@endo/nat": "^5.2.0",
    "@endo/pass-style": "^1.8.1",
    "@endo/patterns": "^1.9.1",
    "@endo/promise-kit": "^1.2.1",
    "import-meta-resolve": "^4.1.0",
    "jessie.js": "^0.3.4"
  },
  "devDependencies": {
    "@agoric/swingset-liveslots": "workspace:*",
    "@endo/bundle-source": "^4.3.2",
    "@endo/init": "^1.1.13",
    "ava": "^8.0.1",
    "c8": "^10.1.3"
  },
  "files": [
    "CHANGELOG.md",
    "src/",
    "scripts/",
    "source-spec-registry.*",
    "tools/",
    "index.*"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": "^22.11"
  },
  "ava": {
    "files": [
      "test/**/*.test.*"
    ],
    "timeout": "20m"
  },
  "typeCoverage": {
    "atLeast": 91
  }
}
