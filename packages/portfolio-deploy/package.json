{
  "name": "@aglocal/portfolio-deploy",
  "private": true,
  "version": "0.1.0",
  "description": "Deployment facilities for the Portfolio contract",
  "type": "module",
  "files": [
    "src",
    "bundles",
    "dist"
  ],
  "scripts": {
    "build": "yarn build:nomin --minify",
    "build:nomin": "esbuild ../portfolio-contract/src/portfolio.contract.ts --bundle --platform=neutral --main-fields=main --outfile=dist/portfolio.contract.bundle.js --metafile=dist/portfolio.contract.meta.json",
    "build:bundle": "npx bundle-source --cache-json dist/ ./dist/portfolio.contract.bundle.js ymax0",
    "build:bundle-id": "sh -c '(printf b1-; jq -r .endoZipBase64Sha512 ./dist/bundle-ymax0.json) >./dist/ymax0.bundleId'",
    "deploy:devnet": "echo '❌ deploy:devnet removed - it used dangerous CoreEval method that destroys the contract' && echo '✅ Use the safe upgrade workflow instead: see README.md or multichain-testing/ymax-ops/Makefile' && exit 1",
    "test": "yarn build && ava",
    "test:c8": "c8 --all $C8_OPTIONS ava",
    "test:xs": "exit 0",
    "lint-fix": "yarn lint:eslint --fix",
    "lint": "yarn run -T run-s --continue-on-error 'lint:*'",
    "lint:eslint": "node ../../scripts/eslint-repo.mjs .",
    "lint:types": "yarn run -T tsgo --tsBuildInfoFile tsconfig.tsgo.tsbuildinfo"
  },
  "dependencies": {
    "@aglocal/portfolio-contract": "workspace:*",
    "@agoric/client-utils": "workspace:*",
    "@agoric/cosmic-proto": "workspace:*",
    "@agoric/deploy-script-support": "workspace:*",
    "@agoric/ertp": "workspace:*",
    "@agoric/internal": "workspace:*",
    "@agoric/notifier": "workspace:*",
    "@agoric/orchestration": "workspace:*",
    "@agoric/pola-io": "workspace:*",
    "@agoric/portfolio-api": "workspace:*",
    "@agoric/store": "workspace:*",
    "@agoric/vat-data": "workspace:*",
    "@agoric/vats": "workspace:*",
    "@agoric/vow": "workspace:*",
    "@agoric/zoe": "workspace:*",
    "@agoric/zone": "workspace:*",
    "@cosmjs/encoding": "^0.36.0",
    "@cosmjs/proto-signing": "^0.36.0",
    "@cosmjs/stargate": "^0.36.0",
    "@endo/errors": "^1.3.1",
    "@endo/eventual-send": "^1.5.0",
    "@endo/far": "^1.1.14",
    "@endo/init": "^1.1.13",
    "@endo/marshal": "^1.10.0",
    "@endo/pass-style": "^1.8.1",
    "@endo/patterns": "^1.9.1",
    "@endo/promise-kit": "^1.2.1",
    "viem": "^2.31.0"
  },
  "devDependencies": {
    "@aglocal/boot": "workspace:*",
    "@agoric/casting": "workspace:*",
    "@agoric/client-utils": "workspace:*",
    "@agoric/portfolio-api": "workspace:*",
    "@agoric/smart-wallet": "workspace:*",
    "@cosmjs/crypto": "^0.36.0",
    "@noble/hashes": "~1.5.0",
    "ava": "^8.0.1",
    "c8": "^10.1.3",
    "esbuild": "^0.25.2",
    "execa": "^9.5.2",
    "ts-blank-space": "^0.6.2",
    "tsd": "^0.33.0"
  },
  "typeCoverage": {
    "atLeast": 97.29
  },
  "engines": {
    "node": "^22.11"
  }
}
