{
  "name": "@agoric/network",
  "version": "0.1.0",
  "description": "Agoric's network protocol API",
  "type": "module",
  "main": "./src/index.js",
  "repository": "https://github.com/Agoric/agoric-sdk",
  "scripts": {
    "build": "exit 0",
    "prepack": "yarn run -T prepack-package",
    "postpack": "yarn run -T postpack-package",
    "test": "ava",
    "test:c8": "c8 --all ${C8_OPTIONS:-} ava",
    "test:xs": "exit 0",
    "lint-fix": "yarn lint:eslint --fix",
    "lint": "yarn run -T run-s --continue-on-error 'lint:*'",
    "lint:types": "yarn run -T tsgo --tsBuildInfoFile tsconfig.tsgo.tsbuildinfo",
    "lint:eslint": "node ../../scripts/eslint-repo.mjs ."
  },
  "keywords": [],
  "author": "Agoric",
  "license": "Apache-2.0",
  "dependencies": {
    "@agoric/internal": "workspace:*",
    "@agoric/store": "workspace:*",
    "@agoric/vat-data": "workspace:*",
    "@endo/base64": "^1.1.1",
    "@endo/errors": "^1.3.1",
    "@endo/far": "^1.1.14",
    "@endo/pass-style": "^1.8.1",
    "@endo/patterns": "^1.9.1",
    "@endo/promise-kit": "^1.2.1"
  },
  "devDependencies": {
    "@agoric/cosmic-proto": "workspace:*",
    "@agoric/swingset-liveslots": "workspace:*",
    "@agoric/swingset-vat": "workspace:*",
    "@agoric/vow": "workspace:*",
    "@agoric/zone": "workspace:*",
    "@endo/bundle-source": "^4.3.2",
    "@endo/init": "^1.1.13",
    "ava": "^8.0.1",
    "c8": "^10.1.3"
  },
  "exports": {
    ".": "./src/index.js",
    "./ibc": "./src/ibc/index.js",
    "./ibc/utils.js": "./src/ibc/utils.js"
  },
  "files": [
    "CHANGELOG.md",
    "src/",
    "scripts/",
    "tools/"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": "^22.11"
  },
  "typeCoverage": {
    "atLeast": 92.88
  }
}
