{
  "private": true,
  "agoricSyntheticChain": {
    "fromTag": "use-upgrade-22"
  },
  "scripts": {
    "build": "yarn run build:sdk && yarn run build:submissions && yarn run build:synthetic-chain",
    "build:sdk": "make -C ../packages/deployment docker-build-sdk",
    "build:submissions": "scripts/build-all-submissions.sh",
    "build:synthetic-chain": "yarn synthetic-chain build",
    "lint-fix": "yarn lint:eslint --fix",
    "lint": "run-s --continue-on-error 'lint:*'",
    "lint:types": "find proposals -maxdepth 2 -name package.json -type f -exec ../node_modules/.bin/tsc -p '{}'/.. ';'",
    "lint:eslint": "eslint .",
    "pretest": "./scripts/prepare-test.sh",
    "test": "yarn synthetic-chain test",
    "doctor": "yarn synthetic-chain doctor"
  },
  "dependencies": {
    "@agoric/synthetic-chain": "^0.7.1"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "npm-run-all": "^4.1.5"
  },
  "packageManager": "yarn@4.12.0",
  "license": "Apache-2.0",
  "resolutions": {
    "@endo/bundle-source": "portal:../node_modules/@endo/bundle-source",
    "@endo/compartment-mapper": "portal:../node_modules/@endo/compartment-mapper",
    "@endo/errors": "npm:^1.3.1",
    "@endo/promise-kit": "npm:^1.2.1",
    "@endo/zip": "npm:^1.1.0",
    "ses": "npm:^2.0.0"
  }
}
