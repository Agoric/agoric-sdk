// Top-level tsconfig for validation across the repo
{
    "extends": [
        "./tsconfig.check.json"
    ],
    "exclude": [
        // Repeat the exclusion from base config because tsconfig extends does not merge arrays.
        "a3p-integration", // vendored package problems
        "multichain-testing", // not relevant for coding loop (and noble-usdn-lab.ts is very slow)
        "**/build",
        "**/bundles",
        "**/coverage",
        "**/dist",
        "**/docs",
        "**/vendor",
        "**/*.umd.js",
        // The following packages are excluded from quickcheck because they change rarely.
        "packages/benchmark",
        "packages/create-dapp",
        "packages/solo",
        "packages/stat-logger",
        "packages/swingset-runner",
        "packages/xsnap-lockdown"
    ]
}
