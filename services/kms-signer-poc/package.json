{
  "name": "@aglocal/kms-signer-poc",
  "private": true,
  "version": "1.0.0",
  "description": "POC: sign Agoric wallet transactions with a non-exportable GCP KMS secp256k1 key, deployed as a Cloud Run gen2 function",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "gcp-build": "tsc -p tsconfig.build.json",
    "start": "functions-framework --target=sign",
    "lint": "yarn run -T run-s --continue-on-error 'lint:*'",
    "lint-fix": "yarn lint:eslint --fix",
    "lint:eslint": "yarn run -T eslint src/",
    "lint:types": "yarn run -T tsgo --tsBuildInfoFile tsconfig.tsgo.tsbuildinfo",
    "test": "ava",
    "test:c8": "c8 --all ${C8_OPTIONS:-} ava",
    "test:xs": "exit 0"
  },
  "keywords": [
    "agoric",
    "kms",
    "signing",
    "cloud-run",
    "poc"
  ],
  "author": "Agoric",
  "license": "Apache-2.0",
  "dependencies": {
    "@agoric/cosmic-proto": "^0.5.0",
    "@cosmjs/amino": "^0.36.0",
    "@cosmjs/crypto": "^0.36.0",
    "@cosmjs/encoding": "^0.36.0",
    "@cosmjs/proto-signing": "^0.36.0",
    "@cosmjs/stargate": "^0.36.0",
    "@google-cloud/functions-framework": "^5.0.5",
    "@google-cloud/kms": "^5.6.0"
  },
  "devDependencies": {
    "@types/node": "~22.9.0",
    "ava": "^8.0.1",
    "c8": "^10.1.3",
    "ts-blank-space": "^0.6.2",
    "typescript": "~6.0.3"
  },
  "ava": {
    "extensions": [
      "js",
      "ts"
    ],
    "files": [
      "test/**/*.test.*"
    ],
    "nodeArguments": [
      "--import=ts-blank-space/register",
      "--no-warnings"
    ],
    "timeout": "30s"
  },
  "engines": {
    "node": "^22.11"
  }
}
