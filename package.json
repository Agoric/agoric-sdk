  "scripts": {
    "prepack-package": "scripts/packing/prepack-package.mjs",
    "postpack-package": "scripts/packing/postpack-package.mjs",
    "clean": "yarn lerna run --no-bail clean",
    "docs": "run-s docs:build docs:update-functions-path",
    "docs:build": "typedoc --tsconfig tsconfig.build.json",
    "docs:update-functions-path": "node ./scripts/update-typedoc-functions-path.cjs",
    "doctor": "./scripts/env-doctor.sh",
    "hooks:install": "./scripts/install-git-hooks.sh",
    "lerna": "lerna",
    "link-cli": "yarn run create-agoric-cli",
    "create-agoric-cli": "node ./scripts/create-agoric-cli.cjs",
    "format": "dprint fmt",
    "lint:format": "dprint check",
    "lint:eslint": "node ./scripts/eslint-repo.mjs",
    "lint-fix": "yarn lerna run --no-bail lint-fix",
    "lint": "yarn run -T run-s --continue-on-error 'lint:*'",
    "lint:packages": "yarn typecheck-packages && echo Some packages have other lint: targets that are ignored",
    "lint:package-names": "./scripts/verify-package-names.js",
    "lint:tools-scope-imports": "node ./scripts/ci/check-tools-scope-imports.mjs",
    "lint:types": "tsgo --tsBuildInfoFile tsconfig.tsgo.tsbuildinfo",
    "lint:scripts": "yarn eslint scripts/*js",
    "test": "yarn lerna run --no-bail test",
    "test:xs": "yarn workspaces foreach --all run test:xs",
    "typecheck-all": "yarn run -T tsgo -p tsconfig.check.json --tsBuildInfoFile tsconfig.check.tsgo.tsbuildinfo",
    "typecheck-packages": "yarn workspaces foreach --all --parallel --verbose run lint:types",
    "build": "yarn workspaces foreach --all --topological run build && scripts/agd-builder.sh stamp yarn-built",
    "postinstall": "scripts/agd-builder.sh stamp yarn-installed",
    "build-lockfiles": "./scripts/update-package-locks.sh",
    "build-ts": "tsc --build tsconfig.build.json",
    "build-xs-worker": "cd packages/xs-vat-worker && yarn build:xs-lin"
  }
}
